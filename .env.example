# consumed by your app (pydantic Settings)

DATABASE_URL=postgresql+psycopg://appuser:localdevpassword@db:5432/shiptrack
APP_ENV=local
LOG_LEVEL=INFO
API_KEY=local-dev-key
AUDIT_LOG_PATH=/app/logs/audit.log

